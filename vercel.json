{
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.7.2" },
    "*.php": { "runtime": "vercel-php@0.7.2" }
  },
  "cleanUrls": true,
  "rewrites": [
    { "source": "/asset/(.*)", "destination": "/asset/$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/$1.php" }
  ]
}